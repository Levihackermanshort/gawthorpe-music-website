rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Rules for Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
                    && incoming().uid == request.auth.uid
                    && incoming().email is string
                    && incoming().email.size() <= 200
                    && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
                    && incoming().uid == existing().uid
                    && incoming().email == existing().email
                    && incoming().createdAt == existing().createdAt;
    }

    // Rules for Inquiries
    match /inquiries/{inquiryId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn()
                    && isValidId(inquiryId)
                    && incoming().id == inquiryId
                    && incoming().userId == request.auth.uid
                    && incoming().name is string && incoming().name.size() <= 150
                    && incoming().email is string && incoming().email.size() <= 200
                    && incoming().service is string && incoming().service.size() <= 100
                    && incoming().status == 'New Demo'
                    && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid)
                    && incoming().id == existing().id
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
    }

    // Rules for Orders
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn()
                    && isValidId(orderId)
                    && incoming().id == orderId
                    && incoming().userId == request.auth.uid
                    && incoming().total is string && incoming().total.size() <= 50
                    && incoming().status is string && incoming().status.size() <= 50
                    && incoming().createdAt == request.time;
    }
  }
}
