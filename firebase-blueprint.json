{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account profiles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Inquiry": {
      "title": "Submission / Inquiry",
      "description": "Artist demos or recording inquiries",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "service": { "type": "string" },
        "link": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "email", "service", "status"]
    },
    "Order": {
      "title": "Shop Order",
      "description": "Orders made by fans on GTMCE store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["id", "items", "total", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile records"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Track submissions and recording requests"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Store orders and ticketing purchases"
    }
  }
}
